<Window x:Class="SnapszerGame.AduValasztoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adu választó" Height="380" Width="550"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1A0A00">
    <Window.Resources>
        <Style x:Key="AduGombStilus" TargetType="Button">
            <Setter Property="Height" Value="130"/>
            <Setter Property="Width" Value="110"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#FFF8E7"/>
            <Setter Property="BorderBrush" Value="#D4A017"/>
            <Setter Property="BorderThickness" Value="2.5"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="4" Opacity="0.55"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFE680"/>
                                <Setter Property="BorderBrush" Value="#FFD700"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#F0C040"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Válassz adu színt!"
                       FontFamily="Georgia" FontSize="32" FontWeight="Bold"
                       Foreground="#D4A017" HorizontalAlignment="Center" Margin="0,0,0,6">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#000" BlurRadius="10" ShadowDepth="2" Opacity="0.7"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="Kattints a kívánt kártyaszínre"
                       FontFamily="Georgia" FontSize="13" FontStyle="Italic"
                       Foreground="#A08040" HorizontalAlignment="Center" Margin="0,0,0,40"/>
            <Canvas HorizontalAlignment="Center" Width="450" Height="190">
                <Button Style="{StaticResource AduGombStilus}" Canvas.Left="10" Canvas.Top="42" Panel.ZIndex="1" RenderTransformOrigin="0.5,1.0" Click="MakkGomb_Click">
                    <Button.RenderTransform>
                        <RotateTransform Angle="-14"/>
                    </Button.RenderTransform>
                    <StackPanel Margin="0,4,0,4">
                        <Image Source="szinek/makk.png" Width="68" Height="68" Margin="0,4,0,0"/>
                        <TextBlock Text="MAKK" FontFamily="Georgia" FontSize="13" FontWeight="Bold" Foreground="#5C3317" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource AduGombStilus}" Canvas.Left="110" Canvas.Top="14" Panel.ZIndex="2" RenderTransformOrigin="0.5,1.0" Click="TokGomb_Click">
                    <Button.RenderTransform>
                        <RotateTransform Angle="-5"/>
                    </Button.RenderTransform>
                    <StackPanel Margin="0,4,0,4">
                        <Image Source="szinek/tok.png" Width="68" Height="68" Margin="0,4,0,0"/>
                        <TextBlock Text="TÖK" FontFamily="Georgia" FontSize="13" FontWeight="Bold" Foreground="#5C3317" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource AduGombStilus}" Canvas.Left="230" Canvas.Top="14" Panel.ZIndex="2" RenderTransformOrigin="0.5,1.0" Click="ZoldGomb_Click">
                    <Button.RenderTransform>
                        <RotateTransform Angle="5"/>
                    </Button.RenderTransform>
                    <StackPanel Margin="0,4,0,4">
                        <Image Source="szinek/zold.png" Width="68" Height="68" Margin="0,4,0,0"/>
                        <TextBlock Text="ZÖLD" FontFamily="Georgia" FontSize="13" FontWeight="Bold" Foreground="#1A5C1A" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource AduGombStilus}" Canvas.Left="330" Canvas.Top="42" Panel.ZIndex="1" RenderTransformOrigin="0.5,1.0" Click="PirosGomb_Click">
                    <Button.RenderTransform>
                        <RotateTransform Angle="14"/>
                    </Button.RenderTransform>
                    <StackPanel Margin="0,4,0,4">
                        <Image Source="szinek/piros.png" Width="68" Height="68" Margin="0,4,0,0"/>
                        <TextBlock Text="PIROS" FontFamily="Georgia" FontSize="13" FontWeight="Bold" Foreground="#8B0000" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>
            </Canvas>
        </StackPanel>
    </Grid>
</Window>
