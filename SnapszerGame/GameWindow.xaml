<Window x:Class="SnapszerGame.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:game="clr-namespace:SnapszerGame.game"
        xmlns:local="clr-namespace:SnapszerGame"
        Title="Jatek" Height="1080" Width="1920" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1A0A00">
 
        <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:MultiplyConverter x:Key="Mul" />
        <local:CardSizeConverter x:Key="CardSize" />
        <!-- Jatekos kartyaja (mindig keppel felfele) -->
        <DataTemplate x:Key="PlayerCardTemplate" DataType="{x:Type game:Card}">
            <Grid Margin="6,0">
                <Grid.Width>
                    <MultiBinding Converter="{StaticResource CardSize}" ConverterParameter="0.12;1.0">
                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}"/>
                        <Binding Path="DataContext.HasAduChosen" RelativeSource="{RelativeSource AncestorType=Window}"/>
                    </MultiBinding>
                </Grid.Width>
                <Grid.Height>
                    <MultiBinding Converter="{StaticResource CardSize}" ConverterParameter="0.18;1.0">
                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}"/>
                        <Binding Path="DataContext.HasAduChosen" RelativeSource="{RelativeSource AncestorType=Window}"/>
                    </MultiBinding>
                </Grid.Height>

                <Border x:Name="CardBorder" Background="Transparent" CornerRadius="6" BorderBrush="Transparent" BorderThickness="0" SnapsToDevicePixels="True" UseLayoutRounding="True">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Image Source="{Binding ImagePath}" Stretch="Uniform" StretchDirection="Both" Opacity="0.96"/>
                    <Border.Effect>
                        <DropShadowEffect Color="#000" BlurRadius="6" ShadowDepth="3" Opacity="0.45"/>
                    </Border.Effect>

                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#000" BlurRadius="6" ShadowDepth="3" Opacity="0.45"/>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1.12" ScaleY="1.12" />
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#000" BlurRadius="12" ShadowDepth="6" Opacity="0.95"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="BorderBrush" Value="#FFD700"/>
                                    <Setter Property="BorderThickness" Value="3"/>
                                    <Setter Property="Opacity" Value="1.0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Ellenseg kartyaja (mindig hatlap, amig a kezeben van) -->
        <DataTemplate x:Key="EnemyCardTemplate" DataType="{x:Type game:Card}">
            <Grid Margin="6,0">
                <Grid.Width>
                    <MultiBinding Converter="{StaticResource CardSize}" ConverterParameter="0.09;1.0">
                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}"/>
                        <Binding Path="DataContext.HasAduChosen" RelativeSource="{RelativeSource AncestorType=Window}"/>
                    </MultiBinding>
                </Grid.Width>
                <Grid.Height>
                    <MultiBinding Converter="{StaticResource CardSize}" ConverterParameter="0.13;1.0">
                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}"/>
                        <Binding Path="DataContext.HasAduChosen" RelativeSource="{RelativeSource AncestorType=Window}"/>
                    </MultiBinding>
                </Grid.Height>

                <Grid>
                    <Image x:Name="FaceImage" Source="{Binding ImagePath}" Stretch="Uniform" StretchDirection="Both" Opacity="0.96" SnapsToDevicePixels="True" UseLayoutRounding="True">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFaceUp}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                    <Image x:Name="BackImage" Source="/SnapszerGame;component/kartyak/hatlap_fuggoleg.png" Stretch="Uniform" StretchDirection="Both" Opacity="0.96" SnapsToDevicePixels="True" UseLayoutRounding="True">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFaceUp}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Grid>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    
    <Grid>
        <!-- Hatter --> 
        <Rectangle Grid.RowSpan="3">
            <Rectangle.Fill> 
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1A0A00" Offset="0"/>
                    <GradientStop Color="#2C1200" Offset="0.5"/>
                    <GradientStop Color="#1A0A00" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Statusz sav -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,15,0,0" 
                Background="#88000000" CornerRadius="4" Padding="10,5" Panel.ZIndex="10">
            <TextBlock Text="{Binding StatuszUzenet}" Foreground="#FFD700" FontFamily="Georgia" FontSize="16" FontWeight="Bold"/>
        </Border>

        <!-- Adu kijelzes (sarokban) -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,12,12,0"
                Background="#88000000" CornerRadius="6" Padding="8" Panel.ZIndex="11"
                Visibility="{Binding HasAduChosen, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="{Binding AduImagePath}" Width="56" Height="56" Margin="0,0,8,0"/>
                <StackPanel>
                    <TextBlock Text="ADU" Foreground="#FFD700" FontFamily="Georgia" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="{Binding AduSzin}" Foreground="#FFF8E7" FontFamily="Georgia" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <Grid>
            <Grid.RowDefinitions>
                <!-- Use star sizing so card areas scale with window and won't clip -->
                <RowDefinition Height="2*"/> <!-- Ellenseg lapjai -->
                <RowDefinition Height="6*"/>   <!-- Jatek ter (Pakli, lerakott lapok) -->
                <RowDefinition Height="2*"/> <!-- Jatekos lapjai -->
            </Grid.RowDefinitions>

            <!-- Ellenseg Keze (Fent) -->
            <ItemsControl Grid.Row="0" ItemsSource="{Binding EllensegLapok}" ItemTemplate="{StaticResource EnemyCardTemplate}" 
                          HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <!-- Jatek ter (Kozepen) -->
            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Pakli terulete -->
                    <ColumnDefinition Width="50"/>   <!-- Tavolsag -->
                    <ColumnDefinition Width="Auto"/> <!-- Lejatszott lapok terulete -->
                </Grid.ColumnDefinitions>

                <!-- Pakli megjelenitese -->
                <Image Grid.Column="0" Source="/SnapszerGame;component/kartyak/hatlap_fuggoleg.png"
                       Stretch="Uniform" StretchDirection="Both">
                    <Image.Width>
                        <MultiBinding Converter="{StaticResource CardSize}" ConverterParameter="0.06;1.0">
                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            <Binding Path="HasAduChosen" RelativeSource="{RelativeSource AncestorType=Window}"/>
                        </MultiBinding>
                    </Image.Width>
                    <Image.Height>
                        <MultiBinding Converter="{StaticResource CardSize}" ConverterParameter="0.09;1.0">
                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            <Binding Path="HasAduChosen" RelativeSource="{RelativeSource AncestorType=Window}"/>
                        </MultiBinding>
                    </Image.Height>
                    <Image.Effect>
                        <DropShadowEffect Color="#000" BlurRadius="8" ShadowDepth="4" Opacity="0.6"/>
                    </Image.Effect>
                </Image>

            </Grid>

            <!-- Jatekos Keze (Lent) -->
            <ItemsControl Grid.Row="2" ItemsSource="{Binding JatekosLapok}" ItemTemplate="{StaticResource PlayerCardTemplate}" 
                          HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

        </Grid>
    </Grid>
</Window>