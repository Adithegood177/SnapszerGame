<Window x:Class="SnapszerGame.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:game="clr-namespace:SnapszerGame.game"
        xmlns:local="clr-namespace:SnapszerGame"
        Title="Jatek" Height="1080" Width="1920" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1A0A00">
 
        <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:MultiplyConverter x:Key="Mul" />
        <local:CardSizeConverter x:Key="CardSize" />
        <local:NullToVisibilityConverter x:Key="NullToVis" />

        <Storyboard x:Key="BemondasAppear">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="-20" To="0" Duration="0:0:0.6" />
        </Storyboard>

        <Storyboard x:Key="BemondasDisappear">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" BeginTime="0:0:3.5" Duration="0:0:0.5" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="0" To="-20" BeginTime="0:0:3.5" Duration="0:0:0.5" />
        </Storyboard>

        <!-- Talon hover animations -->
        <Storyboard x:Key="TalonHoverEnter">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1.08" Duration="0:0:0.12" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1.08" Duration="0:0:0.12" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" To="0.95" Duration="0:0:0.12" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" To="-6" Duration="0:0:0.12" />
        </Storyboard>
        <Storyboard x:Key="TalonHoverLeave">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.12" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.12" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" To="0.6" Duration="0:0:0.12" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" To="0" Duration="0:0:0.12" />
        </Storyboard>

        <!-- Jatekos kartyaja (mindig keppel felfele) -->
        <DataTemplate x:Key="PlayerCardTemplate" DataType="{x:Type game:Card}">
            <Grid Margin="12,0">
                <Grid.Width>
                    <MultiBinding Converter="{StaticResource CardSize}" ConverterParameter="0.16;1.0">
                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}"/>
                        <Binding Path="DataContext.HasAduChosen" RelativeSource="{RelativeSource AncestorType=Window}"/>
                    </MultiBinding>
                </Grid.Width>
                <Grid.Height>
                    <MultiBinding Converter="{StaticResource CardSize}" ConverterParameter="0.24;1.0">
                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}"/>
                        <Binding Path="DataContext.HasAduChosen" RelativeSource="{RelativeSource AncestorType=Window}"/>
                    </MultiBinding>
                </Grid.Height>

                <Border x:Name="CardBorder" Background="Transparent" BorderThickness="0" SnapsToDevicePixels="True" UseLayoutRounding="True">
                    <Image Source="{Binding ImagePath}" Stretch="Uniform" StretchDirection="Both">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Opacity" Value="0.8"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=CardBorder}" Value="True">
                                        <Setter Property="Opacity" Value="1.0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="RenderTransformOrigin" Value="0.5,1" />
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                        <TranslateTransform Y="0" />
                                    </TransformGroup>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#000" BlurRadius="6" ShadowDepth="3" Opacity="0.45"/>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Panel.ZIndex" Value="100"/>
                                </Trigger>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1.15" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1.15" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" To="-30" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Ellenseg kartyaja (mindig hatlap, amig a kezeben van) -->
        <DataTemplate x:Key="EnemyCardTemplate" DataType="{x:Type game:Card}">
            <Grid Margin="6,0">
                <Grid.Width>
                    <MultiBinding Converter="{StaticResource CardSize}" ConverterParameter="0.09;1.0">
                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}"/>
                        <Binding Path="DataContext.HasAduChosen" RelativeSource="{RelativeSource AncestorType=Window}"/>
                    </MultiBinding>
                </Grid.Width>
                <Grid.Height>
                    <MultiBinding Converter="{StaticResource CardSize}" ConverterParameter="0.13;1.0">
                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}"/>
                        <Binding Path="DataContext.HasAduChosen" RelativeSource="{RelativeSource AncestorType=Window}"/>
                    </MultiBinding>
                </Grid.Height>

                <Grid>
                    <Image x:Name="FaceImage" Source="{Binding ImagePath}" Stretch="Uniform" StretchDirection="Both" Opacity="0.96" SnapsToDevicePixels="True" UseLayoutRounding="True">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFaceUp}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                    <Image x:Name="BackImage" Source="/SnapszerGame;component/kartyak/hatlap_fuggoleg.png" Stretch="Uniform" StretchDirection="Both" Opacity="0.96" SnapsToDevicePixels="True" UseLayoutRounding="True">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFaceUp}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Grid>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <!-- Hatter --> 
        <Grid Grid.RowSpan="3" Background="#1a0a00">
            <!-- Asztal -->
            <Border Margin="80,40" CornerRadius="400" BorderBrush="#3b1e08" BorderThickness="20">
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                        <GradientStop Color="#0A6022" Offset="0"/>
                        <GradientStop Color="#053511" Offset="0.7"/>
                        <GradientStop Color="#011806" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="15" Opacity="0.8"/>
                </Border.Effect>
                <!-- Belso asztal arnyek szel -->
                <Border CornerRadius="400" BorderBrush="#000" BorderThickness="3" Opacity="0.4">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="50" ShadowDepth="0"/>
                    </Border.Effect>
                </Border>
            </Border>
        </Grid>

        <!-- Statusz sav -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,15,0,0" 
                Background="#88000000" CornerRadius="4" Padding="10,5" Panel.ZIndex="10">
            <TextBlock Text="{Binding StatuszUzenet}" Foreground="#FFD700" FontFamily="Georgia" FontSize="16" FontWeight="Bold"/>
        </Border>

        <!-- Nyert meccsek (bal fels? sarok) -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="15,15,0,0"
                Background="#88000000" CornerRadius="6" Padding="10,6" Panel.ZIndex="11">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                    <TextBlock Text="Nyert meccsek" Foreground="#FFD700" FontFamily="Georgia" FontSize="12" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Border Background="#2288CC33" CornerRadius="4" Padding="6" Margin="0,0,6,0">
                            <TextBlock Text="{Binding MerkozesNyertJatekos}" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Background="#22CC3333" CornerRadius="4" Padding="6">
                            <TextBlock Text="{Binding MerkozesNyertEllenseg}" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Pontszamlalok -->
        <Border VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="15,0,0,15" 
                Background="#88000000" CornerRadius="6" Padding="15,10" Panel.ZIndex="10" Grid.RowSpan="3">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="ELLENSEG PONT" Foreground="#FFD700" FontFamily="Georgia" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding EllensegPont}" Foreground="#FFF8E7" FontFamily="Georgia" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
        
        <Border VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,15,15,0" 
                Background="#88000000" CornerRadius="6" Padding="15,10" Panel.ZIndex="10" Grid.RowSpan="3">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="PONTJAID" Foreground="#FFD700" FontFamily="Georgia" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding JatekosPont}" Foreground="#FFF8E7" FontFamily="Georgia" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Adu kijelzes (sarokban) -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,120,12,0"
                Background="#88000000" CornerRadius="6" Padding="8" Panel.ZIndex="11"
                Visibility="{Binding HasAduChosen, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="{Binding AduImagePath}" Width="56" Height="56" Margin="0,0,8,0"/>
                <StackPanel>
                    <TextBlock Text="ADU" Foreground="#FFD700" FontFamily="Georgia" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="{Binding AduSzin}" Foreground="#FFF8E7" FontFamily="Georgia" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <!-- Bemondas kiiras kozepen -->
        <Border x:Name="BemondasPanel" Opacity="0" RenderTransformOrigin="0.5,0.5" Background="#AA000000" CornerRadius="8" Padding="12" HorizontalAlignment="Center" VerticalAlignment="Center" Panel.ZIndex="50">
            <Border.RenderTransform>
                <TranslateTransform Y="-20" />
            </Border.RenderTransform>
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <TextBlock Text="" x:Name="BemondasText" Foreground="#FFD700" FontFamily="Georgia" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="" x:Name="BemondasSzinText" Foreground="#FFF8E7" FontFamily="Georgia" FontSize="24" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <!-- Use star sizing so card areas scale with window and won't clip -->
                <RowDefinition Height="2*"/> <!-- Ellenseg lapjai -->
                <RowDefinition Height="3.5*"/>   <!-- Jatek ter (Pakli, lerakott lapok) -->
                <RowDefinition Height="4.5*"/> <!-- Jatekos lapjai -->
            </Grid.RowDefinitions>

            <!-- Ellenseg Keze (Fent) -->
            <ItemsControl Grid.Row="0" ItemsSource="{Binding EllensegLapok}" ItemTemplate="{StaticResource EnemyCardTemplate}" 
                          HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10" ClipToBounds="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <!-- Jatek ter (Kozepen) -->
            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Pakli terulete -->
                    <ColumnDefinition Width="50"/>   <!-- Tavolsag -->
                    <ColumnDefinition Width="Auto"/> <!-- Lejatszott lapok terulete -->
                </Grid.ColumnDefinitions>

                <!-- Pakli helye es kartya kijelolve ("Monopoly" szeru) -->
                <Border Grid.Column="0" BorderBrush="#88FFFFFF" BorderThickness="2" CornerRadius="8" Background="#11FFFFFF" Padding="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Talon area on the left -->
                        <Border x:Name="TalonBorder" Grid.Column="0" Background="#22000000" CornerRadius="6" Padding="8" Margin="0,0,6,0" Cursor="Hand" MouseLeftButtonUp="TalonArea_MouseLeftButtonUp" Visibility="{Binding FelforditottKartya, Converter={StaticResource NullToVis}}" BorderBrush="Transparent" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <TransformGroup>
                                                <ScaleTransform ScaleX="1" ScaleY="1" />
                                                <TranslateTransform Y="0" />
                                            </TransformGroup>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#000" BlurRadius="8" ShadowDepth="4" Opacity="0.6" />
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LehetTalonCsere}" Value="True">
                                            <Setter Property="BorderBrush" Value="#FFFFD700"/>
                                            <Setter Property="BorderThickness" Value="3"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard Storyboard="{StaticResource TalonHoverEnter}" />
                                </EventTrigger>
                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard Storyboard="{StaticResource TalonHoverLeave}" />
                                </EventTrigger>
                            </Border.Triggers>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <TextBlock Text="TALON" Foreground="#FFD700" FontFamily="Georgia" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                <Image Source="{Binding FelforditottKartya.ImagePath}" Width="72" Height="108" Stretch="Uniform" RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <RotateTransform Angle="-12" />
                                    </Image.RenderTransform>
                                    <Image.Effect>
                                        <DropShadowEffect Color="#000" BlurRadius="6" ShadowDepth="4" Opacity="0.6"/>
                                    </Image.Effect>
                                </Image>
                            </StackPanel>
                        </Border>

                        <!-- Sziluett szoveg ures paklira -->
                        <TextBlock Grid.Column="2" Text="PAKLI" Foreground="#55FFFFFF" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        
                        <!-- Pakli megjelenitese -->
                        <Image Grid.Column="2" x:Name="PakliImage" Source="/SnapszerGame;component/kartyak/hatlap_fuggoleg.png" Stretch="Uniform" StretchDirection="Both" Visibility="{Binding PakliVisibility}">
                             <Image.Width>
                                 <MultiBinding Converter="{StaticResource CardSize}" ConverterParameter="0.10;1.0">
                                     <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                     <Binding Path="DataContext.HasAduChosen" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                 </MultiBinding>
                             </Image.Width>
                             <Image.Height>
                                 <MultiBinding Converter="{StaticResource CardSize}" ConverterParameter="0.15;1.0">
                                     <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                     <Binding Path="DataContext.HasAduChosen" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                 </MultiBinding>
                             </Image.Height>
                             <Image.Effect>
                                 <DropShadowEffect Color="#000" BlurRadius="8" ShadowDepth="4" Opacity="0.6"/>
                             </Image.Effect>
                         </Image>
                     </Grid>
                 </Border>

                <!-- Dobott lapok helye kijelzese tulsoldalon -->
                <Border Grid.Column="2" BorderBrush="#88FFFFFF" BorderThickness="2" CornerRadius="8" Background="#11FFFFFF" Padding="4">
                    <Grid>
                        <TextBlock Text="ASZTAL" Foreground="#55FFFFFF" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        
                        <!-- Center table size based on card sizes -->
                        <Grid Background="Transparent">
                            <Grid.Width>
                                <MultiBinding Converter="{StaticResource CardSize}" ConverterParameter="0.22;1.0">
                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding Path="DataContext.HasAduChosen" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                </MultiBinding>
                            </Grid.Width>
                            <Grid.Height>
                                <MultiBinding Converter="{StaticResource CardSize}" ConverterParameter="0.18;1.0">
                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding Path="DataContext.HasAduChosen" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                </MultiBinding>
                            </Grid.Height>
                            

                            <!-- Enemy played card (placed slightly higher and shifted left) -->
                            <Image Source="{Binding EllensegHivottLap.ImagePath}" Stretch="Uniform" StretchDirection="Both" Margin="0,0,40,20" Panel.ZIndex="1">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EllensegHivottLap}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                                <Image.Effect>
                                    <DropShadowEffect Color="#000" BlurRadius="4" ShadowDepth="2" Opacity="0.6"/>
                                </Image.Effect>
                            </Image>

                            <!-- Player played card (placed slightly lower and shifted right, over the enemy card) -->
                            <Image Source="{Binding JatekosHivottLap.ImagePath}" Stretch="Uniform" StretchDirection="Both" Margin="40,20,0,0" Panel.ZIndex="2">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding JatekosHivottLap}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                                <Image.Effect>
                                    <DropShadowEffect Color="#000" BlurRadius="6" ShadowDepth="3" Opacity="0.8"/>
                                </Image.Effect>
                            </Image>
                        </Grid>
                    </Grid>
                </Border>

            </Grid>

            <!-- Jatekos Keze (Lent) -->
            <Grid Grid.Row="2" VerticalAlignment="Top" Margin="0,15,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- 20/40 Bemondas gombok -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    
                    <!-- 20 Bemondas Gomb -->
                    <Button Content="20 Bemondas" Padding="40,15" FontWeight="Bold" FontSize="20" Cursor="Hand" Margin="0,0,30,0"
                            IsEnabled="{Binding Lehet20Bemondani}" Click="Bemond20_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder" Background="#881A1A1A" CornerRadius="6" BorderBrush="#AA444444" BorderThickness="2">
                                    <ContentPresenter x:Name="content" HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="#666666"/>
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="3" Opacity="0.4"/>
                                    </Border.Effect>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="#AA1A1A1A"/>
                                        <Setter TargetName="btnBorder" Property="BorderBrush" Value="#CC888888"/>
                                        <Setter TargetName="content" Property="TextElement.Foreground" Value="#E0E0E0"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsEnabled" Value="True"/>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="btnBorder" Property="Background" Value="#AA137333"/>
                                        <Setter TargetName="btnBorder" Property="BorderBrush" Value="#DD2EFF70"/>
                                        <Setter TargetName="content" Property="TextElement.Foreground" Value="#FFFFFF"/>
                                        <Setter TargetName="btnBorder" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#2EFF70" BlurRadius="15" ShadowDepth="0" Opacity="0.8"/>
                                            </Setter.Value>
                                        </Setter>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- 40 Bemondas Gomb -->
                    <Button Content="40 Bemondas" Padding="40,15" FontWeight="Bold" FontSize="20" Cursor="Hand" 
                            IsEnabled="{Binding Lehet40Bemondani}" Click="Bemond40_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder" Background="#881A1A1A" CornerRadius="6" BorderBrush="#AA444444" BorderThickness="2">
                                    <ContentPresenter x:Name="content" HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="#666666"/>
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="3" Opacity="0.4"/>
                                    </Border.Effect>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="#AA1A1A1A"/>
                                        <Setter TargetName="btnBorder" Property="BorderBrush" Value="#CC888888"/>
                                        <Setter TargetName="content" Property="TextElement.Foreground" Value="#E0E0E0"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsEnabled" Value="True"/>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="btnBorder" Property="Background" Value="#AAA31621"/>
                                        <Setter TargetName="btnBorder" Property="BorderBrush" Value="#DDFF4D4D"/>
                                        <Setter TargetName="content" Property="TextElement.Foreground" Value="#FFFFFF"/>
                                        <Setter TargetName="btnBorder" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#FF4D4D" BlurRadius="15" ShadowDepth="0" Opacity="0.8"/>
                                            </Setter.Value>
                                        </Setter>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Snapszer Gomb -->
                    <Button Content="SNAPSZER" Padding="30,15" FontWeight="Bold" FontSize="20" Cursor="Hand" Margin="30,0,0,0"
                            IsEnabled="{Binding LehetSnapszer}" Click="Snapszer_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder" Background="#881A1A1A" CornerRadius="6" BorderBrush="#AA444444" BorderThickness="2">
                                    <ContentPresenter x:Name="content" HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="#666666"/>
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="3" Opacity="0.4"/>
                                    </Border.Effect>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="#AA1A1A1A"/>
                                        <Setter TargetName="btnBorder" Property="BorderBrush" Value="#CC888888"/>
                                        <Setter TargetName="content" Property="TextElement.Foreground" Value="#FFD966"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsEnabled" Value="True"/>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="btnBorder" Property="Background" Value="#AA221133"/>
                                        <Setter TargetName="btnBorder" Property="BorderBrush" Value="#DDFFD966"/>
                                        <Setter TargetName="content" Property="TextElement.Foreground" Value="#FFFFFF"/>
                                        <Setter TargetName="btnBorder" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#FFD966" BlurRadius="15" ShadowDepth="0" Opacity="0.8"/>
                                            </Setter.Value>
                                        </Setter>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding JatekosLapok}" ItemTemplate="{StaticResource PlayerCardTemplate}" 
                              HorizontalAlignment="Center" ClipToBounds="False" MouseLeftButtonUp="ItemsControl_MouseLeftButtonUp">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>

        </Grid>
    </Grid>
</Window>