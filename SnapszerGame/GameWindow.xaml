<Window x:Class="SnapszerGame.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:game="clr-namespace:SnapszerGame.game"
        Title="Jatek" Height="620" Width="820" WindowStartupLocation="CenterOwner"
        Background="#1A0A00">

    <Window.Resources>
        <!-- Jatekos kartyaja (mindig keppel felfele) -->
        <DataTemplate x:Key="PlayerCardTemplate" DataType="{x:Type game:Card}">
            <Grid Width="80" Height="120" Margin="4,0">
                <Image Source="{Binding ImagePath}" Stretch="UniformToFill">
                    <!-- Arnyek a vizualis kiemeleshez -->
                    <Image.Effect>
                        <DropShadowEffect Color="#000" BlurRadius="6" ShadowDepth="3" Opacity="0.5"/>
                    </Image.Effect>
                </Image>
            </Grid>
        </DataTemplate>

        <!-- Ellenseg kartyaja (mindig hatlap, amig a kezeben van) -->
        <DataTemplate x:Key="EnemyCardTemplate" DataType="{x:Type game:Card}">
            <Grid Width="80" Height="120" Margin="4,0">
                <Image x:Name="FaceImage" Source="{Binding ImagePath}" Stretch="UniformToFill" Visibility="Collapsed"/>

                <!-- Hatlap -->
                <Image x:Name="BackImage" Source="/SnapszerGame;component/kartyak/hatlap_fuggoleg.png" Stretch="UniformToFill" Visibility="Visible">
                     <Image.Effect>
                        <DropShadowEffect Color="#000" BlurRadius="6" ShadowDepth="3" Opacity="0.5"/>
                    </Image.Effect>
                </Image>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <!-- Hatter -->
        <Rectangle Grid.RowSpan="3">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1A0A00" Offset="0"/>
                    <GradientStop Color="#2C1200" Offset="0.5"/>
                    <GradientStop Color="#1A0A00" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Statusz sav -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,15,0,0" 
                Background="#88000000" CornerRadius="4" Padding="10,5" Panel.ZIndex="10">
            <TextBlock Text="{Binding StatuszUzenet}" Foreground="#FFD700" FontFamily="Georgia" FontSize="16" FontWeight="Bold"/>
        </Border>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="160"/> <!-- Ellenseg lapjai -->
                <RowDefinition Height="*"/>   <!-- Jatek ter (Pakli, lerakott lapok) -->
                <RowDefinition Height="160"/> <!-- Jatekos lapjai -->
            </Grid.RowDefinitions>

            <!-- Ellenseg Keze (Fent) -->
            <ItemsControl Grid.Row="0" ItemsSource="{Binding EllensegLapok}" ItemTemplate="{StaticResource EnemyCardTemplate}" 
                          HorizontalAlignment="Center" VerticalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <!-- Jatek ter (Kozepen) -->
            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Pakli terulete -->
                    <ColumnDefinition Width="50"/>   <!-- Tavolsag -->
                    <ColumnDefinition Width="Auto"/> <!-- Lejatszott lapok terulete -->
                </Grid.ColumnDefinitions>

                <!-- Pakli megjelenitese -->
                <Image Grid.Column="0" Source="/SnapszerGame;component/kartyak/hatlap_fuggoleg.png" Width="80" Height="120" Stretch="UniformToFill">
                    <Image.Effect>
                        <DropShadowEffect Color="#000" BlurRadius="8" ShadowDepth="4" Opacity="0.6"/>
                    </Image.Effect>
                </Image>

            </Grid>

            <!-- Jatekos Keze (Lent) -->
            <ItemsControl Grid.Row="2" ItemsSource="{Binding JatekosLapok}" ItemTemplate="{StaticResource PlayerCardTemplate}" 
                          HorizontalAlignment="Center" VerticalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

        </Grid>
    </Grid>
</Window>