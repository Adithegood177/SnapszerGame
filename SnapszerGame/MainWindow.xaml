<Window x:Class="SnapszerGame.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:game="clr-namespace:SnapszerGame.game"
		xmlns:local="clr-namespace:SnapszerGame"
		Title="Snapszer" Height="1080" Width="1920"
		WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#1A0A00">

    <Window.Resources>
		<local:MultiplyConverter x:Key="Mul" />

		<!-- Lebegő animációk a kártya ikonokhoz -->
		<Storyboard x:Key="FloatAnim1" RepeatBehavior="Forever" AutoReverse="True">
			<DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" From="-15" To="15" Duration="0:0:3.5" />
		</Storyboard>
		<Storyboard x:Key="FloatAnim2" RepeatBehavior="Forever" AutoReverse="True">
			<DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" From="-10" To="20" Duration="0:0:4.2" />
		</Storyboard>
		<Storyboard x:Key="FloatAnim3" RepeatBehavior="Forever" AutoReverse="True">
			<DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" From="-20" To="10" Duration="0:0:3.8" />
		</Storyboard>
		<Storyboard x:Key="FloatAnim4" RepeatBehavior="Forever" AutoReverse="True">
			<DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" From="-12" To="18" Duration="0:0:4.5" />
		</Storyboard>

        <!-- Pulzáló cím effekt -->
        <Storyboard x:Key="TitleGlowAnim" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" From="20" To="45" Duration="0:0:2.5" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" From="0.75" To="1.0" Duration="0:0:2.5" />
        </Storyboard>

		<!-- Menü gomb stílus (Felnagyítva kitölti a teret) -->
		<Style x:Key="MenuGombStilus" TargetType="Button">
			<Setter Property="Background" Value="#8B1A1A"/>
			<Setter Property="Foreground" Value="#F5DEB3"/>
			<Setter Property="FontFamily" Value="Georgia"/>
			<Setter Property="FontSize" Value="24"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Height" Value="65"/>
			<Setter Property="Width" Value="320"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="BorderBrush" Value="#D4A017"/>
			<Setter Property="BorderThickness" Value="3"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#B22222"/>
								<Setter Property="BorderBrush" Value="#FFD700"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter Property="Background" Value="#6B0F0F"/>
								<Setter Property="BorderThickness" Value="2"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Adu kártya gomb stílus -->
		<Style x:Key="AduGombStilus" TargetType="Button">
			<Setter Property="Height" Value="130"/>
			<Setter Property="Width" Value="110"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Background" Value="#FFF8E7"/>
			<Setter Property="BorderBrush" Value="#D4A017"/>
			<Setter Property="BorderThickness" Value="2.5"/>
			<Setter Property="FontFamily" Value="Georgia"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
							<Border.Effect>
								<DropShadowEffect Color="#000000" BlurRadius="10"
                                                  ShadowDepth="4" Opacity="0.55"/>
							</Border.Effect>
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#FFE680"/>
								<Setter Property="BorderBrush" Value="#FFD700"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter Property="Background" Value="#F0C040"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>

	<Grid>

		<!-- Háttér és Asztal -->
		<Rectangle>
			<Rectangle.Fill>
				<RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="1" RadiusY="1">
					<GradientStop Color="#2C1200" Offset="0"/>
					<GradientStop Color="#1A0A00" Offset="0.8"/>
					<GradientStop Color="#0A0400" Offset="1"/>
				</RadialGradientBrush>
			</Rectangle.Fill>
		</Rectangle>
        
        <!-- Zöld posztó asztal szerűség középen ami megtöri a teret -->
        <Border Margin="100, 70" CornerRadius="500" BorderBrush="#3b1e08" BorderThickness="25" Opacity="0.95">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.9" RadiusY="0.9">
                    <GradientStop Color="#0F7A2A" Offset="0"/>
                    <GradientStop Color="#074516" Offset="0.7"/>
                    <GradientStop Color="#021C07" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="80" ShadowDepth="25" Opacity="0.95"/>
            </Border.Effect>
            <!-- Arany belső perem dekorációként -->
            <Border CornerRadius="480" BorderBrush="#D4A017" BorderThickness="2" Margin="6" Opacity="0.5">
                <Border.Effect>
                    <DropShadowEffect Color="#FFD700" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
                </Border.Effect>
            </Border>
        </Border>

		<!-- Dekoratív keretek -->
		<Border BorderBrush="#D4A017" BorderThickness="3" Margin="10" CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect Color="#FFD700" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
            </Border.Effect>
        </Border>
		<Border BorderBrush="#8B6914" BorderThickness="1" Margin="20" CornerRadius="10"/>

		<!-- ── MENÜSOR ── -->
		<Menu Background="#2C1200" Foreground="#F5DEB3"
              FontFamily="Georgia" FontSize="16"
              VerticalAlignment="Top" Margin="20,20,20,0"
              BorderBrush="#D4A017" BorderThickness="1,1,1,2" Padding="5">
			<Menu.Resources>
				<Style TargetType="MenuItem">
					<Setter Property="Foreground" Value="#F5DEB3"/>
					<Setter Property="Background" Value="#2C1200"/>
					<Style.Triggers>
						<Trigger Property="IsHighlighted" Value="True">
							<Setter Property="Background" Value="#8B1A1A"/>
							<Setter Property="Foreground" Value="#FFD700"/>
						</Trigger>
					</Style.Triggers>
				</Style>
			</Menu.Resources>
			<MenuItem Header="🃏  Játék" Padding="15,5">
				<MenuItem Header="▶  Játék indítása" Click="StartGomb_Click"/>
				<Separator Background="#D4A017"/>
				<MenuItem Header="✖  Kilépés" Click="KilepesMenu_Click"/>
			</MenuItem>
			<MenuItem Header="ℹ  Névjegy" Padding="15,5">
				<MenuItem Header="Snapszer v1.1" IsEnabled="False"/>
				<MenuItem Header="Magyar kártyajáték" IsEnabled="False"/>
			</MenuItem>
		</Menu>

		<!-- FŐMENÜ PANEL -->
		<Grid Margin="15,80,15,60"
              Visibility="{Binding FomenLathato}">

			<!-- Cím -->
			<StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,40,0,0">
				<TextBlock Text="SNAPSZER"
                           FontFamily="Georgia" FontSize="110" FontWeight="Bold"
                           Foreground="#D4A017" HorizontalAlignment="Center" TextAlignment="Center">
					<TextBlock.Effect>
                        <DropShadowEffect Color="#8B1A1A" BlurRadius="30" ShadowDepth="8" Opacity="1.0" Direction="320"/>
					</TextBlock.Effect>
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard Storyboard="{StaticResource TitleGlowAnim}"/>
                        </EventTrigger>
                    </TextBlock.Triggers>
				</TextBlock>
				<TextBlock Text="Magyar kártyajáték"
                           FontFamily="Georgia" FontSize="32" FontStyle="Italic"
                           Foreground="#E5C060" HorizontalAlignment="Center"
                           Margin="0,5,0,0">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#000" BlurRadius="10" ShadowDepth="3" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>
			</StackPanel>

			<!-- 4 SZÍN IKON – Nagyítva és Animálva középen -->
			<Canvas HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="800" Height="400" Margin="0,40,0,0">

				<!-- MAKK -->
				<Image Source="/SnapszerGame;component/kartyak/makk_asz.png" Width="260" Height="360"
                       Canvas.Left="10" Canvas.Top="80"
                       Panel.ZIndex="1"
                       RenderTransformOrigin="0.5,0.85">
					<Image.RenderTransform>
						<TransformGroup>
                            <RotateTransform Angle="-24"/>
                            <TranslateTransform Y="0" />
                        </TransformGroup>
					</Image.RenderTransform>
					<Image.Effect>
						<DropShadowEffect Color="#000" BlurRadius="20" ShadowDepth="8" Opacity="0.75"/>
					</Image.Effect>
                    <Image.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard Storyboard="{StaticResource FloatAnim1}"/>
                        </EventTrigger>
                    </Image.Triggers>
				</Image>

				<!-- TÖK -->
				<Image Source="/SnapszerGame;component/kartyak/tok_asz.png" Width="280" Height="380"
                       Canvas.Left="180" Canvas.Top="20"
                       Panel.ZIndex="2"
                       RenderTransformOrigin="0.5,0.85">
					<Image.RenderTransform>
                        <TransformGroup>
						    <RotateTransform Angle="-8"/>
                            <TranslateTransform Y="0" />
                        </TransformGroup>
					</Image.RenderTransform>
					<Image.Effect>
						<DropShadowEffect Color="#000" BlurRadius="25" ShadowDepth="12" Opacity="0.8"/>
					</Image.Effect>
                    <Image.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard Storyboard="{StaticResource FloatAnim2}"/>
                        </EventTrigger>
                    </Image.Triggers>
				</Image>

				<!-- ZÖLD -->
				<Image Source="/SnapszerGame;component/kartyak/zold_asz.png" Width="280" Height="380"
                       Canvas.Left="340" Canvas.Top="20"
                       Panel.ZIndex="2"
                       RenderTransformOrigin="0.5,0.85">
					<Image.RenderTransform>
                        <TransformGroup>
						    <RotateTransform Angle="8"/>
                            <TranslateTransform Y="0" />
                        </TransformGroup>
					</Image.RenderTransform>
					<Image.Effect>
						<DropShadowEffect Color="#000" BlurRadius="25" ShadowDepth="12" Opacity="0.8"/>
					</Image.Effect>
                    <Image.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard Storyboard="{StaticResource FloatAnim3}"/>
                        </EventTrigger>
                    </Image.Triggers>
				</Image>

				<!-- PIROS -->
				<Image Source="/SnapszerGame;component/kartyak/piros_asz.png" Width="260" Height="360"
                       Canvas.Left="530" Canvas.Top="80"
                       Panel.ZIndex="1"
                       RenderTransformOrigin="0.5,0.85">
					<Image.RenderTransform>
                        <TransformGroup>
						    <RotateTransform Angle="24"/>
                            <TranslateTransform Y="0" />
                        </TransformGroup>
					</Image.RenderTransform>
					<Image.Effect>
						<DropShadowEffect Color="#000" BlurRadius="20" ShadowDepth="8" Opacity="0.75"/>
					</Image.Effect>
                    <Image.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard Storyboard="{StaticResource FloatAnim4}"/>
                        </EventTrigger>
                    </Image.Triggers>
				</Image>

			</Canvas>

			<!-- Gombok alul -->
			<StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center"
                        Margin="0,0,0,20">
				<Button Content="▶  JÁTÉK INDÍTÁSA"
                        Style="{StaticResource MenuGombStilus}"
                        Margin="0,0,0,20"
                        Click="StartGomb_Click">
                    <Button.Effect>
                        <DropShadowEffect Color="#FFD700" BlurRadius="15" ShadowDepth="2" Opacity="0.6"/>
                    </Button.Effect>
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" From="15" To="35" Duration="0:0:1.5" />
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" From="0.4" To="0.9" Duration="0:0:1.5" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>
				<Button Content="📜  SZABÁLYZAT"
                        Style="{StaticResource MenuGombStilus}"
                        Margin="0,0,0,20"
                        Click="SzabalyzatGomb_Click">
                    <Button.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="4" Opacity="0.5"/>
                    </Button.Effect>
                </Button>
				<Button Content="✖  KILÉPÉS"
                        Style="{StaticResource MenuGombStilus}"
                        Click="KilepesGomb_Click">
                    <Button.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="4" Opacity="0.5"/>
                    </Button.Effect>
                </Button>
			</StackPanel>

		</Grid>

	</Grid>
</Window>
