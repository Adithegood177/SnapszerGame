<Window x:Class="SnapszerGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snapszer" Height="620" Width="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#1A0A00">

	<Window.Resources>

		<!-- Menü gomb stílus -->
		<Style x:Key="MenuGombStilus" TargetType="Button">
			<Setter Property="Background" Value="#8B1A1A"/>
			<Setter Property="Foreground" Value="#F5DEB3"/>
			<Setter Property="FontFamily" Value="Georgia"/>
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Height" Value="48"/>
			<Setter Property="Width" Value="220"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="BorderBrush" Value="#D4A017"/>
			<Setter Property="BorderThickness" Value="2"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#B22222"/>
								<Setter Property="BorderBrush" Value="#FFD700"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter Property="Background" Value="#6B0F0F"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Adu kártya gomb stílus -->
		<Style x:Key="AduGombStilus" TargetType="Button">
			<Setter Property="Height" Value="130"/>
			<Setter Property="Width" Value="110"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Background" Value="#FFF8E7"/>
			<Setter Property="BorderBrush" Value="#D4A017"/>
			<Setter Property="BorderThickness" Value="2.5"/>
			<Setter Property="FontFamily" Value="Georgia"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
							<Border.Effect>
								<DropShadowEffect Color="#000000" BlurRadius="10"
                                                  ShadowDepth="4" Opacity="0.55"/>
							</Border.Effect>
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#FFE680"/>
								<Setter Property="BorderBrush" Value="#FFD700"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter Property="Background" Value="#F0C040"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

	</Window.Resources>

	<Grid>

		<!-- Háttér -->
		<Rectangle>
			<Rectangle.Fill>
				<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
					<GradientStop Color="#1A0A00" Offset="0"/>
					<GradientStop Color="#2C1200" Offset="0.5"/>
					<GradientStop Color="#1A0A00" Offset="1"/>
				</LinearGradientBrush>
			</Rectangle.Fill>
		</Rectangle>

		<!-- Dekoratív keret -->
		<Border BorderBrush="#D4A017" BorderThickness="3" Margin="10" CornerRadius="8"/>
		<Border BorderBrush="#8B6914" BorderThickness="1" Margin="16" CornerRadius="6"/>

		<!-- ── MENÜSOR ── -->
		<Menu Background="#2C1200" Foreground="#F5DEB3"
              FontFamily="Georgia" FontSize="14"
              VerticalAlignment="Top" Margin="15,15,15,0"
              BorderBrush="#D4A017" BorderThickness="1">
			<Menu.Resources>
				<Style TargetType="MenuItem">
					<Setter Property="Foreground" Value="#F5DEB3"/>
					<Setter Property="Background" Value="#2C1200"/>
					<Style.Triggers>
						<Trigger Property="IsHighlighted" Value="True">
							<Setter Property="Background" Value="#8B1A1A"/>
							<Setter Property="Foreground" Value="#FFD700"/>
						</Trigger>
					</Style.Triggers>
				</Style>
			</Menu.Resources>
			<MenuItem Header="🃏  Játék">
				<MenuItem Header="▶  Játék indítása" Click="StartGomb_Click"/>
				<Separator Background="#D4A017"/>
				<MenuItem Header="✖  Kilépés" Click="KilepesMenu_Click"/>
			</MenuItem>
			<MenuItem Header="ℹ  Névjegy">
				<MenuItem Header="Snapszer v1.0" IsEnabled="False"/>
				<MenuItem Header="Magyar kártyajáték" IsEnabled="False"/>
			</MenuItem>
		</Menu>

		<!-- ══════════════════════════════════════
             FŐMENÜ PANEL
        ══════════════════════════════════════ -->
		<Grid Margin="15,50,15,40"
              Visibility="{Binding FomenLathato}">

			<!-- Cím -->
			<StackPanel VerticalAlignment="Top" HorizontalAlignment="Center"
                        Margin="0,18,0,0">
				<TextBlock Text="SNAPSZER"
                           FontFamily="Georgia" FontSize="58" FontWeight="Bold"
                           Foreground="#D4A017" HorizontalAlignment="Center">
					<TextBlock.Effect>
						<DropShadowEffect Color="#8B1A1A" BlurRadius="24"
                                          ShadowDepth="0" Opacity="0.9"/>
					</TextBlock.Effect>
				</TextBlock>
				<TextBlock Text="Magyar kártyajáték"
                           FontFamily="Georgia" FontSize="15" FontStyle="Italic"
                           Foreground="#A08040" HorizontalAlignment="Center"
                           Margin="0,2,0,0"/>
			</StackPanel>

			<!-- 4 SZÍN IKON – legyező elrendezés, egymásba lógva -->
			<Canvas HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="340" Height="170" Margin="0,50,0,0">

				<!-- MAKK – bal külső, -18° -->
				<Image Source="Images/makk.png" Width="115" Height="115"
                       Canvas.Left="5" Canvas.Top="30"
                       Panel.ZIndex="1"
                       RenderTransformOrigin="0.5,0.95">
					<Image.RenderTransform>
						<RotateTransform Angle="-18"/>
					</Image.RenderTransform>
					<Image.Effect>
						<DropShadowEffect Color="#000" BlurRadius="12" ShadowDepth="5" Opacity="0.65"/>
					</Image.Effect>
				</Image>

				<!-- TÖK – bal belső, -6° -->
				<Image Source="Images/tok.png" Width="115" Height="115"
                       Canvas.Left="80" Canvas.Top="10"
                       Panel.ZIndex="2"
                       RenderTransformOrigin="0.5,0.95">
					<Image.RenderTransform>
						<RotateTransform Angle="-6"/>
					</Image.RenderTransform>
					<Image.Effect>
						<DropShadowEffect Color="#000" BlurRadius="12" ShadowDepth="5" Opacity="0.65"/>
					</Image.Effect>
				</Image>

				<!-- ZÖLD – jobb belső, +6° -->
				<Image Source="Images/zold.png" Width="115" Height="115"
                       Canvas.Left="155" Canvas.Top="10"
                       Panel.ZIndex="2"
                       RenderTransformOrigin="0.5,0.95">
					<Image.RenderTransform>
						<RotateTransform Angle="6"/>
					</Image.RenderTransform>
					<Image.Effect>
						<DropShadowEffect Color="#000" BlurRadius="12" ShadowDepth="5" Opacity="0.65"/>
					</Image.Effect>
				</Image>

				<!-- PIROS – jobb külső, +18° -->
				<Image Source="Images/piros.png" Width="115" Height="115"
                       Canvas.Left="225" Canvas.Top="30"
                       Panel.ZIndex="1"
                       RenderTransformOrigin="0.5,0.95">
					<Image.RenderTransform>
						<RotateTransform Angle="18"/>
					</Image.RenderTransform>
					<Image.Effect>
						<DropShadowEffect Color="#000" BlurRadius="12" ShadowDepth="5" Opacity="0.65"/>
					</Image.Effect>
				</Image>

			</Canvas>

			<!-- Gombok alul -->
			<StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center"
                        Margin="0,0,0,8">
				<Button Content="▶  Játék indítása"
                        Style="{StaticResource MenuGombStilus}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,14"
                        Click="StartGomb_Click"/>
				<Button Content="✖  Kilépés"
                        Style="{StaticResource MenuGombStilus}"
                        HorizontalAlignment="Center"
                        Click="KilepesGomb_Click"/>
			</StackPanel>

		</Grid>

		<!-- Státusz sáv -->
		<Border VerticalAlignment="Bottom" Margin="15,0,15,15"
                Background="#2C1200" BorderBrush="#D4A017"
                BorderThickness="1" CornerRadius="4" Height="28">
			<TextBlock Text="{Binding StatuszUzenet}"
                       FontFamily="Georgia" FontSize="12"
                       Foreground="#A08040" FontStyle="Italic"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
		</Border>

	</Grid>
</Window>
